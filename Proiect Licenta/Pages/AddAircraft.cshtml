@page
@model Proiect_Licenta.Pages.AddAircraftModel
@{
    ViewData["Title"] = "Add Aircraft";
}


@if (User.Identity != null && User.Identity.IsAuthenticated && User.IsInRole("Company"))
{

    <h2>Add Aircraft Configuration</h2>

    <div class="card p-4 shadow-sm">
        <form method="post">

            <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

            <div class="form-group mb-3">
                <label class="form-label font-weight-bold">Aircraft Model Name</label>
                <input asp-for="AircraftModelName" class="form-control" placeholder="e.g. Airbus A320" />
                <span asp-validation-for="AircraftModelName" class="text-danger"></span>
            </div>

            <hr />
            <h4>Seat Class Configurations</h4>
            <p class="text-muted small">Leave rows at 0 if the class is not present on this aircraft.</p>

            <div class="row bg-light p-2 my-2 border rounded">
                <div class="col-md-4">
                    <label class="form-label font-weight-bold text-primary">First Class Rows</label>
                    <input asp-for="FirstClassRows" type="number" min="0" class="form-control" />
                </div>
                <div class="col-md-8">
                    <label class="form-label">First Class Layout</label>
                    <input asp-for="FirstClassLayout" class="form-control" placeholder="e.g. AB-CD" />
                </div>
            </div>

            <div class="row bg-light p-2 my-2 border rounded">
                <div class="col-md-4">
                    <label class="form-label font-weight-bold text-success">Business Class Rows</label>
                    <input asp-for="BusinessClassRows" type="number" min="0" class="form-control" />
                </div>
                <div class="col-md-8">
                    <label class="form-label">Business Class Layout</label>
                    <input asp-for="BusinessClassLayout" class="form-control" placeholder="e.g. ABC-DEF" />
                </div>
            </div>

            <div class="row bg-light p-2 my-2 border rounded">
                <div class="col-md-4">
                    <label class="form-label font-weight-bold text-warning">Economy Class Rows</label>
                    <input asp-for="EconomyClassRows" type="number" min="0" class="form-control" />
                </div>
                <div class="col-md-8">
                    <label class="form-label">Economy Class Layout</label>
                    <input asp-for="EconomyClassLayout" class="form-control" placeholder="e.g. ABC-DEF" />
                </div>
            </div>

            <button type="submit" class="btn btn-primary mt-4 px-4">
                Build & Add Aircraft
            </button>
        </form>
    </div>

}
else
{
    <div class="alert alert-danger my-4 shadow-sm">
        <h4><i class="bi bi-shield-lock-fill"></i> Access Denied</h4>
        <p class="mb-0">You do not have the required permissions to access this management console.</p>
    </div>
}



@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}