@page
@model Proiect_Licenta.Pages.FlightModel
@{
    ViewData["Title"] = "Flights";

    var routeData = new Dictionary<string, string>
    {
        { "DepartureAirportId", Model.DepartureAirportId?.ToString() ?? "" },
        { "ArrivalAirportId", Model.ArrivalAirportId?.ToString() ?? "" },
        { "IsRoundTrip", Model.IsRoundTrip.ToString().ToLower() },
        { "MaxPrice", Model.MaxPrice?.ToString() ?? "" },
        { "SelectedDate", Model.SelectedDate?.ToString("yyyy-MM-dd") ?? "" },
        { "ReturnDate", Model.ReturnDate?.ToString("yyyy-MM-dd") ?? "" }
    };
}

<link rel="stylesheet" href="~/css/Flight.css" asp-append-version="true" />
<link href="https://cdnjs.cloudflare.com/ajax/libs/select2/4.0.13/css/select2.min.css" rel="stylesheet" />

<div class="flights-page">

    <div class="flight-search-sidebar">
        <h3>Search Flights</h3>
        <form method="get">
            <div class="mb-3">
                <label>Departure Airport</label>
                <select asp-for="DepartureAirportId" class="form-select airport-search" id="departureAirport">
                    @if (Model.DepartureAirportId != Guid.Empty && Model.DepartureAirportId != null)
                    {
                        <option value="@Model.DepartureAirportId" selected>@Model.SelectedDepartureName</option>
                    }
                </select>
            </div>

            <div class="mb-3">
                <label>Arrival Airport</label>
                <select asp-for="ArrivalAirportId" class="form-select airport-search" id="arrivalAirport">
                    @if (Model.ArrivalAirportId != Guid.Empty && Model.ArrivalAirportId != null)
                    {
                        <option value="@Model.ArrivalAirportId" selected>@Model.SelectedArrivalName</option>
                    }
                </select>
            </div>

            <div class="mb-3">
                <label>Flight Date</label>
                <input asp-for="SelectedDate" type="date" class="form-control" min="@DateTime.Now.ToString("yyyy-MM-dd")" />
            </div>

            <div class="form-check mb-2">
                <input asp-for="IsRoundTrip" class="form-check-input" type="checkbox" id="isRoundTripCheck" />
                <label asp-for="IsRoundTrip" class="form-check-label">Round-trip</label>
            </div>

            <div class="mb-3" id="returnDateWrapper" style="@(Model.IsRoundTrip ? "" : "display:none;")">
                <label>Return Flight Date</label>
                <input asp-for="ReturnDate" type="date" class="form-control" id="returnDateInput" min="@DateTime.Now.ToString("yyyy-MM-dd")" />
            </div>

            <div class="mb-3">
                <label>Maximum Price (€)</label>
                <input asp-for="MaxPrice" type="number" min="0" class="form-control" placeholder="Ex: 300" />
            </div>

            <input type="hidden" name="CurrentPage" value="1" />

            <button type="submit" class="btn btn-primary w-100">Search</button>
        </form>
    </div>

    <div class="flights-container background">
        <h2>Available Flights</h2>

        @* FIX: RoundTripConnectings was missing from the empty-state check, so layover
               round-trip results caused "No flights found" to always display. *@
        @if (!Model.Flights.Any() && !Model.RoundTrips.Any() && !Model.ConnectingFlights.Any() && !Model.RoundTripConnectings.Any())
        {
            <p class="text-center py-4">No flights found.</p>
        }
        else
        {
            <div class="flight-list">
                @if (Model.IsRoundTrip && Model.RoundTripConnectings.Any())
                {
                    <div class="alert alert-info text-center mb-4">
                        No direct round trips found — showing 1-stop options instead.
                    </div>
                    @foreach (var combo in Model.RoundTripConnectings)
                    {
                        <partial name="_RoundTripLayoverCard" model="combo" />
                    }
                }
                else if (Model.IsRoundTrip && Model.RoundTrips.Any())
                {
                    @foreach (var roundTrip in Model.RoundTrips)
                    {
                        <partial name="_RoundTripCard" model="roundTrip" />
                    }
                }
                else if (Model.Flights.Any())
                {
                    @foreach (var flight in Model.Flights)
                    {
                        <partial name="_FlightCard" model="flight" />
                    }
                }
                else if (Model.ConnectingFlights.Any())
                {
                    <div class="alert alert-info text-center mb-4">
                        <i class="bi bi-info-circle"></i> We couldn't find any direct flights, but we found these 1-stop layover options!
                    </div>
                    @foreach (var connectingFlight in Model.ConnectingFlights)
                    {
                        <partial name="_LayoverCard" model="connectingFlight" />
                    }
                }
            </div>

            <nav aria-label="Flight search results navigation" class="mt-4 d-flex justify-content-center">
                <ul class="pagination">
                    <li class="page-item @(Model.HasPreviousPage ? "" : "disabled")">
                        @{
                            routeData["CurrentPage"] = (Model.CurrentPage - 1).ToString();
                        }
                        <a class="page-link" asp-all-route-data="routeData">Previous</a>
                    </li>

                    @for (int i = 1; i <= Model.TotalPages; i++)
                    {
                        if (i == 1 || i == Model.TotalPages || Math.Abs(i - Model.CurrentPage) <= 2)
                        {
                            routeData["CurrentPage"] = i.ToString();
                            <li class="page-item @(i == Model.CurrentPage ? "active" : "")">
                                <a class="page-link" asp-all-route-data="routeData">@i</a>
                            </li>
                        }
                        else if (i == 2 || i == Model.TotalPages - 1)
                        {
                            <li class="page-item disabled"><span class="page-link">...</span></li>
                        }
                    }

                    <li class="page-item @(Model.HasNextPage ? "" : "disabled")">
                        @{
                            routeData["CurrentPage"] = (Model.CurrentPage + 1).ToString();
                        }
                        <a class="page-link" asp-all-route-data="routeData">Next</a>
                    </li>
                </ul>
            </nav>
            <div class="text-center text-muted small mt-2">
                Page @Model.CurrentPage of @Model.TotalPages
            </div>
        }
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script src="https://cdnjs.cloudflare.com/ajax/libs/select2/4.0.13/js/select2.min.js"></script>

    <script>
        $(document).ready(function () {
            function initializeSelect2(selector) {
                $(selector).select2({
                    minimumInputLength: 2,
                    placeholder: "Search airport...",
                    allowClear: true,
                    ajax: {
                        url: '?handler=Airports',
                        dataType: 'json',
                        delay: 250,
                        data: function (params) {
                            return { term: params.term };
                        },
                        processResults: function (data) {
                            return { results: data.results };
                        }
                    }
                });
            }

            initializeSelect2('#departureAirport');
            initializeSelect2('#arrivalAirport');

            const $isRoundTripCheck = $('#isRoundTripCheck');
            const $returnDateWrapper = $('#returnDateWrapper');
            const $departureDateInput = $('input[name="SelectedDate"]');
            const $returnDateInput = $('#returnDateInput');

            function toggleReturnDateVisibility() {
                if ($isRoundTripCheck.is(':checked')) {
                    $returnDateWrapper.slideDown(200);
                } else {
                    $returnDateWrapper.slideUp(200);
                    $returnDateInput.val('');
                }
            }

            function updateReturnDateMinimum() {
                if ($departureDateInput.val()) {
                    $returnDateInput.attr('min', $departureDateInput.val());
                    if ($returnDateInput.val() && $returnDateInput.val() < $departureDateInput.val()) {
                        $returnDateInput.val($departureDateInput.val());
                    }
                }
            }

            $isRoundTripCheck.on('change', toggleReturnDateVisibility);
            $departureDateInput.on('change', updateReturnDateMinimum);

            toggleReturnDateVisibility();
            updateReturnDateMinimum();
        });
    </script>
}
