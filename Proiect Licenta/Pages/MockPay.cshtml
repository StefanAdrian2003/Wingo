@page
@using Proiect_Licenta.Models
@model Proiect_Licenta.Pages.MockPayModel
@{
    ViewData["Title"] = "Payment";

    var multipliers = new Dictionary<TravelClass, decimal>
    {
        { TravelClass.Economy,  1.0m },
        { TravelClass.Business, 2.2m },
        { TravelClass.First,    3.5m }
    };
}

<link rel="stylesheet" href="~/css/MockPay.css" asp-append-version="true" />

<style>
    .passenger-item-block {
        margin-bottom: 14px;
    }

    .baggage-sub-line {
        padding-left: 38px;
        margin-top: 4px;
        display: flex;
        justify-content: space-between;
        align-items: center;
    }

    .baggage-icon {
        font-size: 0.95rem;
        margin-right: 6px;
    }

    .secondary-text {
        font-size: 0.85rem;
        color: #6c757d;
    }

    .item-description {
        flex-grow: 1;
        text-align: left;
        margin-left: 8px;
    }

    .flight-segment-header {
        margin-top: 12px;
        margin-bottom: 8px;
        background-color: #f8f9fa;
        padding: 6px 10px;
        border-radius: 4px;
    }
</style>

<div class="background">
    <div class="pay-layout">

        <div class="pay-panel">
            <div class="page-header">
                <h2 class="page-title">Payment</h2>
            </div>

            @if (!ModelState.IsValid)
            {
                <div class="error-alert">
                    ⚠️ Something went wrong. Please try again.
                </div>
            }

            <div class="card-preview" id="cardPreview">
                <div class="card-top">
                    <span class="card-bank">WinGo Pay</span>
                    <span class="card-chip">▣</span>
                </div>
                <div class="card-number-display" id="cardNumberDisplay">
                    •••• •••• •••• ••••
                </div>
                <div class="card-bottom">
                    <div class="card-holder-display">
                        <span class="card-label">CARDHOLDER</span>
                        <span id="cardHolderDisplay">YOUR NAME</span>
                    </div>
                    <div class="card-expiry-display">
                        <span class="card-label">EXPIRES</span>
                        <span id="cardExpiryDisplay">MM/YY</span>
                    </div>
                </div>
            </div>

            <form method="post" id="payForm">
                @Html.AntiForgeryToken()

                <div class="form-group">
                    <label class="form-label">Cardholder Name</label>
                    <input type="text" id="cardHolder" class="form-input"
                           placeholder="Name on card" maxlength="30" required />
                </div>

                <div class="form-group">
                    <label class="form-label">Card Number</label>
                    <input type="text" id="cardNumber" class="form-input"
                           placeholder="1234 5678 9012 3456" maxlength="19" required />
                </div>

                <div class="form-row">
                    <div class="form-group">
                        <label class="form-label">Expiry Date</label>
                        <input type="text" id="cardExpiry" class="form-input"
                               placeholder="MM/YY" maxlength="5" required />
                    </div>

                    <div class="form-group">
                        <label class="form-label">CVV</label>
                        <input type="text" id="cardCvv" class="form-input cvv-input"
                               placeholder="•••" maxlength="3" required />
                    </div>
                </div>

                <div class="voucher-box">
                    <label>Voucher</label>
                    <select asp-for="SelectedVoucherId">
                        <option value="">No voucher</option>
                        @foreach (var v in Model.UserVouchers)
                        {
                            <option value="@v.Id" data-discount="@v.DiscountPercent">
                                @v.Name - @v.DiscountPercent%
                            </option>
                        }
                    </select>
                </div>

                <div class="secure-note">
                    🔒 This is a demo — no real payment is processed
                </div>

                <button type="submit" class="btn-pay" id="payBtn">
                    Pay
                </button>
            </form>
        </div>

        <div class="order-summary">
            <div class="summary-sticky">
                <h3 class="summary-title">Order Summary</h3>

                @if (Model.Flight != null && Model.SelectedSeats.Any())
                {
                    <div class="flight-mini flight-segment-header">
                        <div class="flight-mini-info">
                            <span class="flight-num">@Model.Flight.FlightNumber</span>
                            <span class="flight-route">
                                @Model.Flight.DepartureAirport.IATACode → @Model.Flight.ArrivalAirport.IATACode
                            </span>
                        </div>
                    </div>

                    @for (int i = 0; i < Model.SelectedSeats.Count; i++)
                    {
                        var seat = Model.SelectedSeats[i];
                        var travelClass = seat.SeatSection.TravelClass;
                        var seatPrice = Math.Round(Model.Flight.Price * multipliers[travelClass], 2);
                        var baggage = Model.Session?.Baggage?.ElementAtOrDefault(i);
                        var bagPrice = baggage?.TotalBaggagePrice ?? 0m;

                        <div class="passenger-item-block">
                            <div class="order-line">
                                <span class="seat-chip @travelClass.ToString().ToLower()">
                                    @seat.SeatNumber
                                </span>
                                <span class="item-description">@travelClass Class Seat</span>
                                <span class="order-line-price">€@seatPrice</span>
                            </div>

                            @if (bagPrice > 0)
                            {
                                <div class="baggage-sub-line">
                                    <div>
                                        <span class="baggage-icon">🧳</span>
                                        <span class="secondary-text">Checked Baggage Add-on</span>
                                    </div>
                                    <span class="secondary-text">+€@bagPrice</span>
                                </div>
                            }
                        </div>
                    }
                }

                @if (Model.Leg2Flight != null && Model.Leg2Seats.Any())
                {
                    <div class="summary-divider"></div>
                    <div class="flight-mini flight-segment-header">
                        <div class="flight-mini-info">
                            <span class="flight-num">@Model.Leg2Flight.FlightNumber</span>
                            <span class="flight-route">
                                @Model.Leg2Flight.DepartureAirport.IATACode → @Model.Leg2Flight.ArrivalAirport.IATACode
                            </span>
                        </div>
                    </div>

                    @for (int i = 0; i < Model.Leg2Seats.Count; i++)
                    {
                        var seat = Model.Leg2Seats[i];
                        var travelClass = seat.SeatSection.TravelClass;
                        var seatPrice = Math.Round(Model.Leg2Flight.Price * multipliers[travelClass], 2);
                        var baggage = Model.Session?.Leg2Baggage?.ElementAtOrDefault(i);
                        var bagPrice = baggage?.TotalBaggagePrice ?? 0m;

                        <div class="passenger-item-block">
                            <div class="order-line">
                                <span class="seat-chip @travelClass.ToString().ToLower()">
                                    @seat.SeatNumber
                                </span>
                                <span class="item-description">@travelClass Class Seat</span>
                                <span class="order-line-price">€@seatPrice</span>
                            </div>

                            @if (bagPrice > 0)
                            {
                                <div class="baggage-sub-line">
                                    <div>
                                        <span class="baggage-icon">🧳</span>
                                        <span class="secondary-text">Checked Baggage Add-on</span>
                                    </div>
                                    <span class="secondary-text">+€@bagPrice</span>
                                </div>
                            }
                        </div>
                    }
                }

                @if (Model.ReturnFlight != null && Model.ReturnSeats.Any())
                {
                    <div class="summary-divider"></div>
                    <div class="flight-mini flight-segment-header">
                        <div class="flight-mini-info">
                            <span class="flight-num">@Model.ReturnFlight.FlightNumber</span>
                            <span class="flight-route">
                                @Model.ReturnFlight.DepartureAirport.IATACode → @Model.ReturnFlight.ArrivalAirport.IATACode
                            </span>
                        </div>
                    </div>

                    @for (int i = 0; i < Model.ReturnSeats.Count; i++)
                    {
                        var seat = Model.ReturnSeats[i];
                        var travelClass = seat.SeatSection.TravelClass;
                        var seatPrice = Math.Round(Model.ReturnFlight.Price * multipliers[travelClass], 2);
                        var baggage = Model.Session?.ReturnBaggage?.ElementAtOrDefault(i);
                        var bagPrice = baggage?.TotalBaggagePrice ?? 0m;

                        <div class="passenger-item-block">
                            <div class="order-line">
                                <span class="seat-chip @travelClass.ToString().ToLower()">
                                    @seat.SeatNumber
                                </span>
                                <span class="item-description">@travelClass Class Seat</span>
                                <span class="order-line-price">€@seatPrice</span>
                            </div>

                            @if (bagPrice > 0)
                            {
                                <div class="baggage-sub-line">
                                    <div>
                                        <span class="baggage-icon">🧳</span>
                                        <span class="secondary-text">Checked Baggage Add-on</span>
                                    </div>
                                    <span class="secondary-text">+€@bagPrice</span>
                                </div>
                            }
                        </div>
                    }
                }

                @if (Model.ReturnLeg2Flight != null && Model.ReturnLeg2Seats.Any())
                {
                    <div class="summary-divider"></div>
                    <div class="flight-mini flight-segment-header">
                        <div class="flight-mini-info">
                            <span class="flight-num">@Model.ReturnLeg2Flight.FlightNumber</span>
                            <span class="flight-route">
                                @Model.ReturnLeg2Flight.DepartureAirport.IATACode → @Model.ReturnLeg2Flight.ArrivalAirport.IATACode
                            </span>
                        </div>
                    </div>

                    @for (int i = 0; i < Model.ReturnLeg2Seats.Count; i++)
                    {
                        var seat = Model.ReturnLeg2Seats[i];
                        var travelClass = seat.SeatSection.TravelClass;
                        var seatPrice = Math.Round(Model.ReturnLeg2Flight.Price * multipliers[travelClass], 2);
                        var baggage = Model.Session?.ReturnLeg2Baggage?.ElementAtOrDefault(i);
                        var bagPrice = baggage?.TotalBaggagePrice ?? 0m;

                        <div class="passenger-item-block">
                            <div class="order-line">
                                <span class="seat-chip @travelClass.ToString().ToLower()">
                                    @seat.SeatNumber
                                </span>
                                <span class="item-description">@travelClass Class Seat</span>
                                <span class="order-line-price">€@seatPrice</span>
                            </div>

                            @if (bagPrice > 0)
                            {
                                <div class="baggage-sub-line">
                                    <div>
                                        <span class="baggage-icon">🧳</span>
                                        <span class="secondary-text">Checked Baggage Add-on</span>
                                    </div>
                                    <span class="secondary-text">+€@bagPrice</span>
                                </div>
                            }
                        </div>
                    }
                }

                <div class="summary-divider"></div>

                @if (Model.DiscountAmount > 0)
                {
                    <div class="discount-row">
                        <span>Voucher discount</span>
                        <span class="discount-amount">-€@Model.DiscountAmount</span>
                    </div>
                    <div class="summary-divider"></div>
                }

                <div id="voucherDiscountRow" class="discount-row" style="display:none;">
                    <span>Voucher discount</span>
                    <span id="voucherDiscountAmount" class="discount-amount"></span>
                </div>

                <div class="grand-total-row">
                    <span>Total</span>
                    <span id="grandTotalAmount" class="grand-total-amount">
                        €@Model.GrandTotal
                    </span>
                </div>

            </div>
        </div>

    </div>
</div>

@section Scripts {
    <script>
        // ── CARD NUMBER FORMATTING ──
        document.getElementById('cardNumber').addEventListener('input', function (e) {
            let val = e.target.value.replace(/\D/g, '').substring(0, 16);
            e.target.value = val.match(/.{1,4}/g)?.join(' ') || val;

            const display = val.padEnd(16, '•').match(/.{1,4}/g).join(' ');
            document.getElementById('cardNumberDisplay').textContent = display;
        });

        // ── EXPIRY FORMATTING ──
        document.getElementById('cardExpiry').addEventListener('input', function (e) {
            let val = e.target.value.replace(/\D/g, '').substring(0, 4);
            if (val.length >= 3) val = val.substring(0, 2) + '/' + val.substring(2);
            e.target.value = val;
            document.getElementById('cardExpiryDisplay').textContent = val || 'MM/YY';
        });

        // ── HOLDER NAME ──
        document.getElementById('cardHolder').addEventListener('input', function (e) {
            const val = e.target.value.toUpperCase() || 'YOUR NAME';
            document.getElementById('cardHolderDisplay').textContent = val;
        });

        // ── CVV FOCUS FLIPS CARD ──
        document.getElementById('cardCvv').addEventListener('focus', () => {
            document.getElementById('cardPreview').classList.add('flipped');
        });

        document.getElementById('cardCvv').addEventListener('blur', () => {
            document.getElementById('cardPreview').classList.remove('flipped');
        });

        // ── VOUCHER PREVIEW ──
        const voucherSelect = document.querySelector('[name="SelectedVoucherId"]');
        const totalElement = document.getElementById('grandTotalAmount');
        const baseTotal = parseFloat('@Model.GrandTotal'.replace(',', '.'));

        voucherSelect.addEventListener('change', function () {
            const selectedOption = this.options[this.selectedIndex];
            const discountPercent = parseInt(selectedOption.dataset.discount || 0);

            if (discountPercent > 0) {
                document.getElementById('voucherDiscountRow').style.display = 'flex';

                const discountAmount = (baseTotal * discountPercent / 100);
                const finalTotal = baseTotal - discountAmount;

                document.getElementById('voucherDiscountAmount').textContent =
                    '-€' + discountAmount.toFixed(2);

                totalElement.textContent = '€' + finalTotal.toFixed(2);
            } else {
                document.getElementById('voucherDiscountRow').style.display = 'none';
                totalElement.textContent = '€' + baseTotal.toFixed(2);
            }
        });

        // ── PAY BUTTON LOADING STATE ──
        document.getElementById('payForm').addEventListener('submit', function () {
            const btn = document.getElementById('payBtn');
            btn.textContent = 'Processing...';
            btn.disabled = true;
        });
    </script>
}