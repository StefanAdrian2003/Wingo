@model Proiect_Licenta.Models.RoundTripConnecting

<style>
    /* Aliniere la structura fixă a întregului ecosistem de carduri */
    .roundtrip-layover-card {
        width: 100%;
        max-width: 440px;
        background: #ffffff;
        border: 1px solid rgba(0, 0, 0, 0.06);
        border-radius: 16px;
        padding: 20px;
        box-shadow: 0 10px 30px -5px rgba(0, 0, 0, 0.04);
        display: flex;
        flex-direction: column;
        gap: 16px;
        box-sizing: border-box;
        transition: transform 0.2s ease, box-shadow 0.2s ease;
    }

        .roundtrip-layover-card:hover {
            transform: translateY(-2px);
            box-shadow: 0 12px 35px -5px rgba(124, 58, 237, 0.12); /* Glow Indigo subtil */
        }

    /* BLOCURI DE CĂLĂTORIE (DUS / ÎNTORS) */
    .journey-block {
        display: flex;
        flex-direction: column;
        gap: 10px;
        background: #f8fafc;
        padding: 14px;
        border-radius: 12px;
    }

    .journey-badge-header {
        display: flex;
        align-items: center;
        gap: 6px;
        font-size: 0.75rem;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 0.5px;
    }

    .badge-outbound-layover {
        color: #2563eb;
    }

    .badge-return-layover {
        color: #7c3aed;
    }

    /* MINI-LINII DE ESCALĂ INTRACARD */
    .inner-layover-bar {
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 6px;
        background: #fffbeb;
        border: 1px dashed #fde68a;
        padding: 4px;
        border-radius: 6px;
        font-size: 0.75rem;
        font-weight: 600;
        color: #b45309;
    }

    .leg-row {
        display: flex;
        justify-content: space-between;
        align-items: center;
        font-size: 0.85rem;
    }

    .leg-airport {
        font-weight: 700;
        color: #1e293b;
    }

    .leg-time {
        color: #64748b;
        font-weight: 500;
    }

    /* BUNDLE FARE COMPLET */
    .ultra-price-box {
        background: linear-gradient(135deg, #f5f3ff 0%, #ede9fe 100%);
        border: 1px solid #ddd6fe;
        padding: 12px;
        border-radius: 10px;
        display: flex;
        justify-content: space-between;
        align-items: center;
        width: 100%;
    }

    .ultra-price-label {
        font-size: 0.85rem;
        font-weight: 700;
        color: #5b21b6;
    }

    .ultra-price {
        font-size: 1.25rem;
        font-weight: 800;
        color: #6d28d9;
    }

    /* ULTRA ACTION BUTTON */
    .book-ultra-btn {
        display: block;
        width: 100%;
        text-align: center;
        background: #7c3aed;
        color: #ffffff;
        font-weight: 700;
        font-size: 0.95rem;
        padding: 12px;
        border-radius: 10px;
        text-decoration: none;
        box-shadow: 0 4px 12px rgba(124, 58, 237, 0.25);
        transition: background 0.2s, transform 0.1s;
        border: none;
    }

        .book-ultra-btn:hover {
            background: #6d28d9;
            color: #ffffff;
        }

        .book-ultra-btn:active {
            transform: scale(0.98);
        }
</style>

<div class="roundtrip-layover-card">

    <div class="journey-block" style="border-left: 3px solid #2563eb;">
        <div class="journey-badge-header badge-outbound-layover">
            <i class="bi bi-airplane-engines"></i> Outbound Journey (1 Stop)
        </div>

        <div class="leg-row">
            <div>
                <span class="leg-airport">@Model.OutboundJourney.Leg1.DepartureAirport.IATACode</span>
                <span class="leg-time">(@Model.OutboundJourney.Leg1.DepartureTime.ToString("HH:mm"))</span>
                <span class="text-muted mx-1">→</span>
                <span class="leg-airport">@Model.OutboundJourney.Leg1.ArrivalAirport.IATACode</span>
                <span class="leg-time">(@Model.OutboundJourney.Leg1.ArrivalTime.ToString("HH:mm"))</span>
            </div>
            <div class="airline-name" style="font-size: 0.75rem;">@Model.OutboundJourney.Leg1.Airline.Name</div>
        </div>

        <div class="inner-layover-bar">
            <i class="bi bi-clock-history"></i>
            <span>Layover in @Model.OutboundJourney.Leg1.ArrivalAirport.City: @Model.OutboundJourney.LayoverDuration.ToString(@"hh\h\ mm\m")</span>
        </div>

        <div class="leg-row">
            <div>
                <span class="leg-airport">@Model.OutboundJourney.Leg2.DepartureAirport.IATACode</span>
                <span class="leg-time">(@Model.OutboundJourney.Leg2.DepartureTime.ToString("HH:mm"))</span>
                <span class="text-muted mx-1">→</span>
                <span class="leg-airport">@Model.OutboundJourney.Leg2.ArrivalAirport.IATACode</span>
                <span class="leg-time">(@Model.OutboundJourney.Leg2.ArrivalTime.ToString("HH:mm"))</span>
            </div>
            <div class="airline-name" style="font-size: 0.75rem;">@Model.OutboundJourney.Leg2.Airline.Name</div>
        </div>
    </div>

    <div class="journey-block" style="border-left: 3px solid #7c3aed;">
        <div class="journey-badge-header badge-return-layover">
            <i class="bi bi-airplane-engines" style="transform: rotate(180deg);"></i> Return Journey (1 Stop)
        </div>

        <div class="leg-row">
            <div>
                <span class="leg-airport">@Model.ReturnJourney.Leg1.DepartureAirport.IATACode</span>
                <span class="leg-time">(@Model.ReturnJourney.Leg1.DepartureTime.ToString("HH:mm"))</span>
                <span class="text-muted mx-1">→</span>
                <span class="leg-airport">@Model.ReturnJourney.Leg1.ArrivalAirport.IATACode</span>
                <span class="leg-time">(@Model.ReturnJourney.Leg1.ArrivalTime.ToString("HH:mm"))</span>
            </div>
            <div class="airline-name" style="font-size: 0.75rem;">@Model.ReturnJourney.Leg1.Airline.Name</div>
        </div>

        <div class="inner-layover-bar">
            <i class="bi bi-clock-history"></i>
            <span>Layover in @Model.ReturnJourney.Leg1.ArrivalAirport.City: @Model.ReturnJourney.LayoverDuration.ToString(@"hh\h\ mm\m")</span>
        </div>

        <div class="leg-row">
            <div>
                <span class="leg-airport">@Model.ReturnJourney.Leg2.DepartureAirport.IATACode</span>
                <span class="leg-time">(@Model.ReturnJourney.Leg2.DepartureTime.ToString("HH:mm"))</span>
                <span class="text-muted mx-1">→</span>
                <span class="leg-airport">@Model.ReturnJourney.Leg2.ArrivalAirport.IATACode</span>
                <span class="leg-time">(@Model.ReturnJourney.Leg2.ArrivalTime.ToString("HH:mm"))</span>
            </div>
            <div class="airline-name" style="font-size: 0.75rem;">@Model.ReturnJourney.Leg2.Airline.Name</div>
        </div>
    </div>

    <div class="flight-card-body" style="display: flex; flex-direction: column; gap: 12px; margin-top: auto;">
        <div class="ultra-price-box">
            <span class="ultra-price-label">Full Package Fare (4 Flights)</span>
            <span class="ultra-price">€@Model.TotalPrice.ToString("0.00")</span>
        </div>

        @if (User.Identity != null && User.Identity.IsAuthenticated && !User.IsInRole("Company"))
        {
            <div class="w-100">
                <a asp-page="/BookingPassenger"
                   asp-route-id="@Model.OutboundJourney.Leg1.Id"
                   asp-route-leg2Id="@Model.OutboundJourney.Leg2.Id"
                   asp-route-returnId="@Model.ReturnJourney.Leg1.Id"
                   asp-route-retLeg2Id="@Model.ReturnJourney.Leg2.Id"
                   class="book-ultra-btn">
                    Book Full Journey Bundle
                </a>
            </div>
        }
    </div>
</div>