@model Proiect_Licenta.Models.Post

<style>
    .custom-modal-scrollbar::-webkit-scrollbar {
        width: 6px;
    }

    .custom-modal-scrollbar::-webkit-scrollbar-thumb {
        background-color: #cbd5e1;
        border-radius: 10px;
    }

    .custom-modal-scrollbar::-webkit-scrollbar-track {
        background-color: transparent;
    }
</style>

<div class="modal fade"
     id="commentsModal-@Model.Id"
     tabindex="-1"
     data-bs-focus="false"
     data-bs-container="body">
    <div class="modal-dialog modal-dialog-centered modal-xl">
        <div class="modal-content" style="border-radius: 16px; border: none; box-shadow: 0 25px 50px -12px rgba(0,0,0,0.25);">

            <div class="modal-header" style="border-bottom: 1px solid #f1f5f9; padding: 20px 24px;">
                <h5 class="modal-title" style="font-weight: 700; color: #1e293b;">@Model.Title</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>

            <div class="modal-body row g-0" style="height: 600px; padding: 24px; overflow: hidden;">

                <div class="col-md-6 d-flex flex-column" style="border-right: 1px solid #e5e7eb; padding-right: 24px; height: 100%; overflow: hidden;">

                    <div style="height: 65%; width: 100%; background-color: #f8fafc; border-radius: 12px; overflow: hidden; display: flex; align-items: center; justify-content: center; flex-shrink: 0; margin-bottom: 16px;">
                        @if (!string.IsNullOrEmpty(Model.ImagePath))
                        {
                            <img src="@Model.ImagePath" style="width: 100%; height: 100%; object-fit: contain;" alt="Post content media file" />
                        }
                        else
                        {
                            <span class="text-muted fs-7">No preview image available</span>
                        }
                    </div>

                    <div class="custom-modal-scrollbar" style="height: 31%; width: 100%; overflow-y: auto; flex-shrink: 0; padding-right: 8px;">
                        @if (!string.IsNullOrWhiteSpace(Model.Description))
                        {
                            <div style="font-size: 0.95rem; color: #334155; line-height: 1.6; text-align: left; white-space: pre-wrap; overflow-wrap: break-word; word-break: normal;">@Model.Description</div>
                        }
                        else
                        {
                            <div style="font-size: 0.95rem; text-align: left;" class="text-muted fst-italic">No description provided for this post.</div>
                        }
                    </div>
                </div>

                <div class="col-md-6 d-flex flex-column" style="padding-left: 24px; height: 100%; overflow: hidden;">

                    <div id="comments-list-@Model.Id" class="custom-modal-scrollbar" style="flex: 1; overflow-y: auto; border-bottom: 1px solid #f1f5f9; padding-bottom: 15px; min-height: 0;">
                        <partial name="_CommentsList" model="Model" />
                    </div>

                    <form class="mt-3"
                          hx-post="/_Actions?handler=Comment&postId=@Model.Id"
                          hx-target="#comments-list-@Model.Id"
                          hx-swap="innerHTML"
                          hx-on="htmx:afterRequest: this.reset()">

                        @Html.AntiForgeryToken()

                        <textarea name="content"
                                  class="form-control mb-2"
                                  rows="3"
                                  style="border-radius: 10px; resize: none; border-color: #cbd5e1;"
                                  placeholder="Share your thoughts with the community..."
                                  required></textarea>

                        <button type="submit" class="btn btn-primary btn-sm w-100 py-2" style="border-radius: 8px; font-weight: 600;">
                            Post Comment
                        </button>
                    </form>
                </div>

            </div>

        </div>
    </div>
</div>