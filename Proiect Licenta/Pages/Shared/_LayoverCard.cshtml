@model Proiect_Licenta.Models.ConnectingFlight

<style>
    /* Aliniere la structura de bază a FlightCard */
    .layover-flight-card {
        width: 100%;
        max-width: 440px;
        background: #ffffff;
        border: 1px solid rgba(0, 0, 0, 0.06);
        border-radius: 16px;
        padding: 20px;
        box-shadow: 0 10px 30px -5px rgba(0, 0, 0, 0.04);
        display: flex;
        flex-direction: column;
        gap: 16px;
        box-sizing: border-box;
        transition: transform 0.2s ease, box-shadow 0.2s ease;
    }

        .layover-flight-card:hover {
            transform: translateY(-2px);
            box-shadow: 0 12px 35px -5px rgba(245, 158, 11, 0.1); /* Glow portocaliu subtil pentru scale */
        }

    /* SEGMENTE DE ZBOR */
    .segment-container {
        display: flex;
        flex-direction: column;
        gap: 8px;
        background: #f8fafc;
        padding: 12px;
        border-radius: 12px;
        border-left: 3px solid #3b82f6;
    }

    .segment-header {
        display: flex;
        align-items: center;
        justify-content: space-between;
        flex-wrap: wrap;
        gap: 8px;
    }

    .leg-badge {
        font-size: 0.7rem;
        font-weight: 700;
        text-transform: uppercase;
        background: #3b82f6;
        color: white;
        padding: 2px 6px;
        border-radius: 4px;
    }

    .flight-number-sub {
        font-size: 0.85rem;
        font-weight: 700;
        color: #1e293b;
    }

    /* TIMELINE / ESCALĂ */
    .layover-divider {
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 8px;
        background: #fffbeb;
        border: 1px dashed #fde68a;
        padding: 8px;
        border-radius: 10px;
        font-size: 0.8rem;
        font-weight: 700;
        color: #b45309;
    }

    /* PRICE BOX MULTI-STOP */
    .layover-price-box {
        background: linear-gradient(135deg, #fffbeb 0%, #fef3c7 100%);
        border: 1px solid #fde68a;
        padding: 12px;
        border-radius: 10px;
        display: flex;
        justify-content: space-between;
        align-items: center;
        width: 100%;
    }

    .layover-price-label {
        font-size: 0.85rem;
        font-weight: 700;
        color: #92400e;
    }

    .layover-price {
        font-size: 1.25rem;
        font-weight: 800;
        color: #d97706;
    }

    /* BUTON SPECIAL CASSETTE */
    .book-layover-btn {
        display: block;
        width: 100%;
        text-align: center;
        background: #f59e0b;
        color: #ffffff;
        font-weight: 700;
        font-size: 0.95rem;
        padding: 12px;
        border-radius: 10px;
        text-decoration: none;
        box-shadow: 0 4px 12px rgba(245, 158, 11, 0.2);
        transition: background 0.2s, transform 0.1s;
        border: none;
    }

        .book-layover-btn:hover {
            background: #d97706;
            color: #ffffff;
        }

        .book-layover-btn:active {
            transform: scale(0.98);
        }
</style>

<div class="layover-flight-card">

    <!-- ZBOR 1 (LEG 1) -->
    <div class="segment-container">
        <div class="segment-header">
            <span class="leg-badge">Leg 1</span>
            <span class="flight-number-sub">@Model.Leg1.FlightNumber</span>

            <div class="flight-airline">
                @if (!string.IsNullOrEmpty(Model.Leg1.Airline.LogoUrl))
                {
                    <img src="@Model.Leg1.Airline.LogoUrl" alt="Airline Logo" class="airline-logo" />
                }
                <span class="airline-name">@Model.Leg1.Airline.Name</span>
            </div>

            <a asp-page="/FlightInfo" asp-route-id="@Model.Leg1.Id" class="flight-link">
                <span class="details-link">Details →</span>
            </a>
        </div>

        <div class="flight-route" style="padding: 6px 0; background: transparent;">
            <span>@Model.Leg1.DepartureAirport.IATACode</span>
            <span class="route-arrow">→</span>
            <span>@Model.Leg1.ArrivalAirport.IATACode</span>
        </div>

        <div class="d-flex justify-content-between text-start mt-1">
            <div>
                <span class="flight-label">Dep</span>
                <span class="flight-value d-block">@Model.Leg1.DepartureTime.ToString("g")</span>
            </div>
            <div class="text-end">
                <span class="flight-label">Arr</span>
                <span class="flight-value d-block">@Model.Leg1.ArrivalTime.ToString("g")</span>
            </div>
        </div>
    </div>

    <!-- TIMELINE INTERMEDIAR (ESCALA) -->
    <div class="layover-divider">
        <i class="bi bi-clock-history"></i>
        <span>Escală în @Model.Leg1.ArrivalAirport.City (@Model.LayoverDuration.ToString(@"hh\h\ mm\m"))</span>
    </div>

    <!-- ZBOR 2 (LEG 2) -->
    <div class="segment-container" style="border-left-color: #10b981;">
        <div class="segment-header">
            <span class="leg-badge" style="background: #10b981;">Leg 2</span>
            <span class="flight-number-sub">@Model.Leg2.FlightNumber</span>

            <div class="flight-airline">
                @if (!string.IsNullOrEmpty(Model.Leg2.Airline.LogoUrl))
                {
                    <img src="@Model.Leg2.Airline.LogoUrl" alt="Airline Logo" class="airline-logo" />
                }
                <span class="airline-name">@Model.Leg2.Airline.Name</span>
            </div>

            <a asp-page="/FlightInfo" asp-route-id="@Model.Leg2.Id" class="flight-link">
                <span class="details-link">Details →</span>
            </a>
        </div>

        <div class="flight-route" style="padding: 6px 0; background: transparent;">
            <span>@Model.Leg2.DepartureAirport.IATACode</span>
            <span class="route-arrow">→</span>
            <span>@Model.Leg2.ArrivalAirport.IATACode</span>
        </div>

        <div class="d-flex justify-content-between text-start mt-1">
            <div>
                <span class="flight-label">Dep</span>
                <span class="flight-value d-block">@Model.Leg2.DepartureTime.ToString("g")</span>
            </div>
            <div class="text-end">
                <span class="flight-label">Arr</span>
                <span class="flight-value d-block">@Model.Leg2.ArrivalTime.ToString("g")</span>
            </div>
        </div>
    </div>

    <!-- COSTA TOTAL & REZERVARE -->
    <div class="flight-card-body" style="display: flex; flex-direction: column; gap: 12px; margin-top: auto;">
        <div class="layover-price-box">
            <span class="layover-price-label">Total Fare (1 Stop)</span>
            <span class="layover-price">€@Model.TotalPrice</span>
        </div>

        @if (User.Identity != null && User.Identity.IsAuthenticated && !User.IsInRole("Company"))
        {
            <div class="w-100">
                <a asp-page="/BookingPassenger"
                   asp-route-id="@Model.Leg1.Id"
                   asp-route-returnId="@Guid.Empty"
                   asp-route-leg2Id="@Model.Leg2.Id"
                   class="book-layover-btn">
                    Book Layover Journey
                </a>
            </div>
        }
    </div>
</div>