@model Proiect_Licenta.Models.Post

<style>
    /* 1. STRUCTURĂ ȘI DIMENSIUNI STRICT FIXE PENTRU TOT CARDUL */
    .post-card {
        width: 100%;
        max-width: 460px; 
        height: 520px;         /* Înălțime fixă blocată: toate cardurile vor fi egale în feed */
        margin: 0 auto;   
        background: #ffffff;
        border: 1px solid rgba(0, 0, 0, 0.06);
        border-radius: 16px;
        padding: 20px;
        box-shadow: 0 10px 30px -5px rgba(0, 0, 0, 0.05);
        
        /* Distribuie elementele pe verticală pe poziții fixe */
        display: flex;
        flex-direction: column;
        justify-content: space-between; 
        box-sizing: border-box;
    }

    /* 2. HEADER FIX (Înălțime determinată) */
    .post-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        width: 100%;
        height: 24px;
    }

    .post-actions-zone {
        display: flex;
        align-items: center;
        gap: 8px;
    }

    .post-user-link {
        font-weight: 600;
        color: #3b82f6;
    }

    /* 3. TITLU FIX (Dacă e prea lung, pune puncte-puncte pe un singur rând) */
    .post-title {
        font-weight: 700;
        font-size: 1.15rem;
        color: #1e293b;
        line-height: 1.3;
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
        height: 24px;
        margin-top: 4px;
    }

    /* 4. CASĂ FIXĂ PENTRU IMAGINE (WINDOW MULT MAI CURAT) */
    .post-image-wrapper {
        width: 100%;
        height: 260px;         /* Înălțime fixă pentru zona foto */
        border-radius: 12px;
        overflow: hidden; 
        background-color: #ffffff; /* Fundal alb curat (diagrama din stânga se va confunda cu fundalul) */
        display: flex;
        align-items: center;
        justify-content: center;
    }

    .post-image {
        width: 100%;
        height: 100%;
        object-fit: contain;    /* Păstrează detaliile intacte (bun pentru diagrame/text din poze) */
        display: block;
    }

    /* Dacă vrei ca pozele de tip peisaj/mașină să umple complet rama fără margini albe deloc, 
       schimbă mai sus din 'contain' în 'cover'. Pentru proiecte tehnice, 'contain' e mai sigur. */

    /* 5. DESCRIERE FIXĂ (Alocă spațiu fix de exact 2 rânduri, chiar dacă textul e scurt) */
    .post-description-container {
        height: 42px;          /* Spațiu fix alocat pentru text */
        display: flex;
        align-items: center;
    }

    .post-description {
        display: -webkit-box;
        -webkit-line-clamp: 2; /* Maxim 2 rânduri */
        -webkit-box-orient: vertical;
        overflow: hidden;
        text-overflow: ellipsis;
        font-size: 0.92rem;
        color: #64748b;
        margin: 0;
        line-height: 1.5;
    }
    
    .no-description {
        font-style: italic;
        color: #cbd5e1;
        font-size: 0.9rem;
    }

    /* 6. ZONA DE FOOTER FIXĂ (Like, See Post, Dată) */
    .post-footer-zone {
        display: flex;
        flex-direction: column;
        gap: 8px;
        margin-top: auto;      /* Împinge tot footer-ul pe linia de jos a cardului */
    }

    .post-stats {
        display: flex;
        align-items: center;
        justify-content: space-between;
        padding-top: 8px;
        border-top: 1px solid rgba(0, 0, 0, 0.04);
        height: 32px;
    }

    .creation-date {
        font-size: 0.78rem;
        color: #94a3b8;
        text-align: right;
        height: 16px;
    }

    /* BUTOANE */
    .btn-report {
        background: none;
        border: none;
        color: #dc3545;
        font-size: 0.85rem;
        font-weight: 600;
        cursor: pointer;
        padding: 4px 10px;
        border-radius: 6px;
        transition: background 0.2s;
    }

    .btn-report:hover {
        background: rgba(220, 53, 69, 0.08);
    }

    .btn-delete {
        background: none;
        border: none;
        color: #64748b;
        font-size: 0.9rem;
        cursor: pointer;
        padding: 4px 8px;
        border-radius: 6px;
    }

    .btn-delete:hover {
        background: rgba(0, 0, 0, 0.05);
        color: #1e293b;
    }
</style>

<div class="post-card">
    <div class="post-header">
        <div class="post-user-zone">
            @if (User.Identity.IsAuthenticated && User.Identity.Name == Model.User.UserName)
            {
                <a asp-area="Identity" asp-page="/Account/Manage/Profile" class="post-user-link text-decoration-none">
                    @Model.User.UserName (You)
                </a>
            }
            else
            {
                <a asp-page="/CustomProfile" asp-route-username="@Model.User.UserName" class="post-user-link text-decoration-none">
                    @Model.User.UserName
                </a>
            }
        </div>

        <div class="post-actions-zone">
            @if (User.Identity.IsAuthenticated && User.Identity.Name != Model.User.UserName)
            {
                <button type="button" class="btn-report" onclick="openReportModal('@Model.Id', 'Post')">
                    Report
                </button>
            }

            @if (User.Identity.IsAuthenticated && (User.Identity.Name == Model.User.UserName || User.IsInRole("Admin")))
            {
                <button type="button" class="btn-delete" onclick="openDeleteModal('@Model.Id', 'Post')">
                    ✖
                </button>
            }
        </div>
    </div>

    <div class="post-title" title="@Model.Title">@Model.Title</div>

    <div class="post-image-wrapper">
        <img src="@Model.ImagePath" alt="Post image" class="post-image" />
    </div>

    <div class="post-description-container">
        @if (!string.IsNullOrWhiteSpace(Model.Description))
        {
            <p class="post-description">@Model.Description</p>
        }
        else
        {
            <span class="no-description">No description provided.</span>
        }
    </div>

    <div class="post-footer-zone">
        <div class="post-stats">
            <form method="post" asp-page="/_Actions" asp-page-handler="Like" asp-route-postId="@Model.Id" class="d-inline">
                <button hx-post="/_Actions?handler=Like&postId=@Model.Id" hx-target="#like-count-@Model.Id" hx-swap="outerHTML" class="btn btn-light btn-sm rounded-pill px-3">
                    ❤️ <span id="like-count-@Model.Id">@Model.Likes.Count</span>
                </button>
            </form>

            <button type="button" class="btn btn-link text-decoration-none p-0" data-bs-toggle="modal" data-bs-target="#commentsModal-@Model.Id">
                See post
            </button>
        </div>

        <div class="creation-date">
            @Model.DateOfCreation.ToString("g")
        </div>
    </div>
</div>