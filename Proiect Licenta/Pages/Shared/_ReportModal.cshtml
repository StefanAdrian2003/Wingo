<style>

    .modal.show {
        pointer-events: none;
    }

    .custom-modal,
    .custom-modal * {
        pointer-events: auto;
    }

    .modal-overlay,
    .custom-modal {
        display: none;
        position: fixed !important;
        z-index: 9999999 !important;
        left: 0;
        top: 0;
        width: 100vw;
        height: 100vh;
        background: rgba(0,0,0,0.5);
        justify-content: center;
        align-items: center;
    }

    .custom-modal-content {
        background: white;
        width: 500px;
        max-width: 90%;
        padding: 25px;
        border-radius: 14px;
        box-shadow: 0 10px 30px rgba(0,0,0,0.2);
    }

</style>

<div id="reportModal" class="custom-modal">

    <div class="custom-modal-content">

        <div class="d-flex justify-content-between align-items-center mb-3">

            <h4 id="reportModalTitle">
                Report
            </h4>

            <button type="button"
                    onclick="closeReportModal()">
                ✖
            </button>

        </div>

        <p id="reportModalText">
            Are you sure you want to report this content?
        </p>

        <form method="post"
              asp-page="/_Actions"
              asp-page-handler="Report">

            <input type="hidden"
                   id="reportEntityId"
                   name="entityId" />

            <input type="hidden"
                   id="reportEntityType"
                   name="type" />

            <div class="mb-3">

                <label class="form-label">
                    Reason
                </label>

                <textarea name="reason"
                          class="form-control"
                          rows="4"
                          maxlength="500"
                          placeholder="Explain why you are reporting this..."
                          required></textarea>

            </div>

            <button type="submit"
                    class="btn btn-danger w-100">

                Submit Report

            </button>

        </form>

    </div>

</div>