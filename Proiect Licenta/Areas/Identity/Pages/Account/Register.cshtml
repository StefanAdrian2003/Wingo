@page
@model RegisterModel
@{
    ViewData["Title"] = "Register";
}


<link rel="stylesheet" href="~/css/Register.css" asp-append-version="true" />

<div class="background">
    <h1>@ViewData["Title"]</h1>

    <div class="mb-3">
        <button type="button" id="btnNormal" class="btn btn-primary">Normal</button>
        <button type="button" id="btnCompany" class="btn btn-outline-secondary">Companie</button>
    </div>


    <form id="registerForm" asp-route-returnUrl="@Model.ReturnUrl" method="post" enctype="multipart/form-data">
        <h2>Create a new account.</h2>
        <hr />
        <div asp-validation-summary="ModelOnly" class="text-danger" role="alert"></div>

        <div class="form-floating mb-3">
            <input asp-for="Input.Username" class="form-control" aria-required="true" placeholder="username" />
            <label asp-for="Input.Username">Username (Public Profile Name)</label>
            <span asp-validation-for="Input.Username" class="text-danger"></span>
        </div>

        <div class="form-floating mb-3">
            <input asp-for="Input.FirstName" class="form-control" aria-required="true" placeholder="First Name" />
            <label asp-for="Input.FirstName">First Name</label>
            <span asp-validation-for="Input.FirstName" class="text-danger"></span>
        </div>
        <div class="form-floating mb-3">
            <input asp-for="Input.LastName" class="form-control" aria-required="true" placeholder="Last Name" />
            <label asp-for="Input.LastName">Last Name</label>
            <span asp-validation-for="Input.LastName" class="text-danger"></span>
        </div>

        <div class="form-floating mb-3">
            <input asp-for="Input.Email" class="form-control" autocomplete="username" aria-required="true" placeholder="name@example.com" />
            <label asp-for="Input.Email">Email Address</label>
            <span asp-validation-for="Input.Email" class="text-danger"></span>
        </div>
        <div class="form-floating mb-3">
            <input asp-for="Input.Password" class="form-control" autocomplete="new-password" aria-required="true" placeholder="password" />
            <label asp-for="Input.Password">Password</label>
            <span asp-validation-for="Input.Password" class="text-danger"></span>
        </div>
        <div class="form-floating mb-3">
            <input asp-for="Input.ConfirmPassword" class="form-control" autocomplete="new-password" aria-required="true" placeholder="password" />
            <label asp-for="Input.ConfirmPassword">Confirm Password</label>
            <span asp-validation-for="Input.ConfirmPassword" class="text-danger"></span>
        </div>


        <div id="companyFields" style="display:none;">
            <div class="form-floating mb-3">
                <input asp-for="Input.CompanyName" class="form-control" aria-required="true" placeholder="Company Name" />
                <label asp-for="Input.CompanyName">Company Name</label>
                <span asp-validation-for="Input.CompanyName" class="text-danger"></span>
            </div>
            <div class="form-floating mb-3">
                <input asp-for="Input.IATACode" class="form-control" aria-required="true" placeholder="IATA Code" />
                <label asp-for="Input.IATACode">IATA Code</label>
                <span asp-validation-for="Input.IATACode" class="text-danger"></span>
            </div>
            <div class="form-floating mb-3">
                <input asp-for="Input.Country" class="form-control" aria-required="true" placeholder="Country" />
                <label asp-for="Input.Country">Country</label>
                <span asp-validation-for="Input.Country" class="text-danger"></span>
            </div>
            <div class="form-floating mb-3">
                <input asp-for="Input.LogoFile" type="file" class="form-control" aria-required="true" placeholder="Logo URL" />
                <label asp-for="Input.LogoFile">Logo</label>
                <span asp-validation-for="Input.LogoFile" class="text-danger"></span>
            </div>
        </div>


        <input asp-for="Input.IsCompany" type="hidden" id="Input_IsCompany" value="false" />

        <button id="registerSubmit" type="submit" class="w-100 btn btn-lg btn-primary">Register</button>
    </form>

</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />

    <script>
        const btnNormal = document.getElementById('btnNormal');
        const btnCompany = document.getElementById('btnCompany');
        const companyFields = document.getElementById('companyFields');
        const isCompanyInput = document.getElementById('Input_IsCompany');

        btnNormal.addEventListener('click', () => {
            companyFields.style.display = 'none';
            isCompanyInput.value = 'false';

            btnNormal.classList.add('btn-primary');
            btnNormal.classList.remove('btn-outline-primary');
            btnCompany.classList.add('btn-outline-secondary');
            btnCompany.classList.remove('btn-secondary');
        });

        btnCompany.addEventListener('click', () => {
            companyFields.style.display = 'block';
            isCompanyInput.value = 'true';

            btnCompany.classList.add('btn-secondary');
            btnCompany.classList.remove('btn-outline-secondary');
            btnNormal.classList.add('btn-outline-primary');
            btnNormal.classList.remove('btn-primary');
        });
    </script>
}